# Frontend .env.example - Copy this file to .env and fill in the values

# API Configuration
VITE_API_BASE_URL=http://127.0.0.1:8000/api
VITE_API_HOST=127.0.0.1
VITE_API_PORT=8000

# Stripe Configuration
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here

# Frontend Server Configuration
VITE_HOST=127.0.0.1
VITE_PORT=5173

# WebSocket Configuration
VITE_WS_PROTOCOL=ws
VITE_WS_HOST=127.0.0.1
VITE_WS_PORT=8000

# App Configuration
VITE_APP_NAME=OWL Eye
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_LOCATION_TRACKING=true
VITE_ENABLE_CROWD_MONITORING=true
VITE_ENABLE_CROWD_HEATMAP=true
VITE_ENABLE_SAFETY_ALERTS=true
VITE_ENABLE_TICKETS=true
VITE_ENABLE_PAYMENTS=true
