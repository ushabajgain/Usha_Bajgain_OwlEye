# Backend .env.example - Copy this file to .env and fill in the values

# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration (MySQL)
DB_ENGINE=django.db.backends.mysql
DB_NAME=Usha_Bajgain_OwlEye_db
DB_USER=root
DB_PASSWORD=your-password-here
DB_HOST=127.0.0.1
DB_PORT=3307

# Redis Configuration
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# Email Configuration (Gmail SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-here
DEFAULT_FROM_EMAIL=OwlEye <your-email@gmail.com>

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-secret-here

# Frontend Configuration
FRONTEND_URL=http://localhost:5173

# JWT Configuration (in minutes and days)
ACCESS_TOKEN_LIFETIME=60
REFRESH_TOKEN_LIFETIME=1440

# Axes Security (Rate Limiting)
AXES_FAILURE_LIMIT=20
AXES_COOLOFF_TIME=1

# Time Zone
TIME_ZONE=Asia/Kathmandu
